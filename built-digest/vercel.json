{
  "crons": [
    {
      "path": "/api/scrape",
      "schedule": "0 7 * * *"
    }
  ],
  "functions": {
    "api/scrape.js": {
      "maxDuration": 60
    },
    "api/news.js": {
      "maxDuration": 10
    },
    "api/data.js": {
      "maxDuration": 30
    },
    "api/add-news.js": {
      "maxDuration": 10
    },
    "api/delete-news.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/noticia/:id",
      "destination": "/article.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}
